{
  "name": "MTG Rakdos Carnival",
  "author": "Jen the Dev MTG Collection",
  "themes": [
    {
      "name": "MTG Rakdos Carnival",
      "appearance": "dark",
      "style": {
        "background": "#14080d",
        "foreground": "#ffb3c1",
        "text": "#ffb3c1",
        "text.accent": "#c9184a",
        "text.muted": "#70404f",
        "editor.background": "#14080d",
        "editor.foreground": "#ffb3c1",
        "editor.active_line.background": "#ffffff0a",
        "editor.line_number": "#70404f",
        "editor.active_line_number": "#c9184a",
        "editor.gutter.background": "#14080d",
        "surface.background": "#ffffff08",
        "element.background": "#ffffff10",
        "element.hover": "#ffffff18",
        "border": "#70404f",
        "border.focused": "#c9184a",
        "tab_bar.background": "#14080d",
        "tab.active_background": "#ffffff08",
        "tab.inactive_background": "#14080d",
        "panel.background": "#ffffff05",
        "title_bar.background": "#14080d",
        "status_bar.background": "#14080d",
        "terminal.background": "#14080d",
        "terminal.foreground": "#ffb3c1",
        "terminal.ansi.black": "#14080d",
        "terminal.ansi.red": "#ff5555",
        "terminal.ansi.green": "#ff758f",
        "terminal.ansi.yellow": "#c9184a",
        "terminal.ansi.blue": "#ff4d6d",
        "terminal.ansi.magenta": "#ffb3c1",
        "terminal.ansi.cyan": "#c9184a",
        "terminal.ansi.white": "#ffb3c1",
        "syntax": {
          "keyword": {
            "color": "#ff4d6d",
            "font_weight": 600
          },
          "string": {
            "color": "#ff758f"
          },
          "comment": {
            "color": "#70404f",
            "font_style": "italic"
          },
          "function": {
            "color": "#ffb3c1",
            "font_weight": 500
          },
          "type": {
            "color": "#c9184a"
          },
          "number": {
            "color": "#c9184a"
          },
          "boolean": {
            "color": "#c9184a"
          },
          "operator": {
            "color": "#ffb3c1"
          },
          "variable": {
            "color": "#ffb3c1"
          },
          "property": {
            "color": "#ffb3c1"
          },
          "constant": {
            "color": "#ff4d6d",
            "font_weight": 600
          },
          "punctuation": {
            "color": "#70404f"
          },
          "tag": {
            "color": "#c9184a"
          },
          "attribute": {
            "color": "#ffb3c1"
          },
          "constructor": {
            "color": "#c9184a"
          },
          "embedded": {
            "color": "#ff758f"
          },
          "emphasis": {
            "font_style": "italic"
          },
          "strong": {
            "font_weight": 700
          },
          "link": {
            "color": "#c9184a",
            "underline": true
          }
        }
      }
    }
  ]
