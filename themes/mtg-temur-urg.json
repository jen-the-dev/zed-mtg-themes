        "tab_bar.background": "#081018",
        "tab.active_background": "#ffffff08",
        "tab.inactive_background": "#081018",
        "panel.background": "#ffffff05",
        "title_bar.background": "#081018",
        "status_bar.background": "#081018",
        "terminal.background": "#081018",
        "terminal.foreground": "#9fe7ff",
        "terminal.ansi.black": "#081018",
        "terminal.ansi.red": "#ff5555",
        "terminal.ansi.green": "#8ecae6",
        "terminal.ansi.yellow": "#219ebc",
        "terminal.ansi.blue": "#023047",
        "terminal.ansi.magenta": "#9fe7ff",
        "terminal.ansi.cyan": "#219ebc",
        "terminal.ansi.white": "#9fe7ff",
        "syntax": {
          "keyword": {
