        "terminal.background": "#120d10",
        "terminal.foreground": "#ffd6a5",
        "terminal.ansi.black": "#120d10",
        "terminal.ansi.red": "#ff5555",
        "terminal.ansi.green": "#ff9f1c",
        "terminal.ansi.yellow": "#ff6f59",
        "terminal.ansi.blue": "#ff595e",
        "terminal.ansi.magenta": "#ffd6a5",
        "terminal.ansi.cyan": "#ff6f59",
        "terminal.ansi.white": "#ffd6a5",
