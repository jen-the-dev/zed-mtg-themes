          },
          "type": {
            "color": "#d00000"
          },
          "number": {
            "color": "#d00000"
          },
          "boolean": {
            "color": "#d00000"
          },
          "operator": {
            "color": "#ffd6a5"
          },
          "variable": {
            "color": "#ffd6a5"
          },
          "property": {
            "color": "#ffd6a5"
          },
          "constant": {
            "color": "#dc2f02",
            "font_weight": 600
          },
          "punctuation": {
            "color": "#735f52"
          },
          "tag": {
            "color": "#d00000"
          },
          "attribute": {
            "color": "#ffd6a5"
          },
          "constructor": {
            "color": "#d00000"
          },
          "embedded": {
            "color": "#ffba08"
          },
          "emphasis": {
            "font_style": "italic"
          },
          "strong": {
            "font_weight": 700
          },
          "link": {
            "color": "#d00000",
            "underline": true
          }
        }
